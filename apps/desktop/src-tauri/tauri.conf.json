{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlenderAgent Desktop",
  "version": "0.1.0",
  "identifier": "com.openai.blenderagentdesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "BlenderAgent Desktop",
        "width": 1240,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
